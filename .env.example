# Copy to `.env` (never commit `.env`). Loaded via python-dotenv in `app.main`.

# Required for `POST /predict` to return 200: Postgres connection URL used by SQLAlchemy.
# Examples:
#   postgresql+psycopg2://user:password@localhost:5432/smartticket
#   postgresql+psycopg2://user:pass@host.supabase.co:5432/postgres
DATABASE_URL=

# Optional: artifact / dataset paths (defaults live under repo root — see app/core/config.py)
# SMARTTICKET_MODEL_PATH=
# SMARTTICKET_VECTORIZER_PATH=
# SMARTTICKET_DATASET_PATH=
